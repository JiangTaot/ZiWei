{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "紫薇斗数",
        "navigationBarBackgroundColor": "#FFFFFF",
        "navigationBarTextStyle": "black"
      }
    },
    {
      "path": "pages/chart/index",
      "style": {
        "navigationBarTitleText": "排盘",
        "navigationBarBackgroundColor": "#FFFFFF",
        "navigationBarTextStyle": "black"
      }
    },
    {
      "path": "pages/mine/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#FFFFFF",
        "navigationBarTextStyle": "black",
        "enablePullDownRefresh": true,
        "backgroundColor": "#F8F5F0"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages/result",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "命盘",
            "navigationBarBackgroundColor": "#1A1A1E",
            "navigationBarTextStyle": "white"
          }
        }
      ]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["pages/result"]
    },
    "pages/chart/index": {
      "network": "all",
      "packages": ["pages/result"]
    }
  },
  "globalStyle": {
    "backgroundColor": "#FFFFFF",
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#FFFFFF",
    "navigationBarTitleText": "紫薇斗数",
    "navigationBarTextStyle": "black"
  },
  "tabBar": {
    "color": "#9E9E9E",
    "selectedColor": "#C04B3E",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/chart/index",
        "text": "排盘"
      },
      {
        "pagePath": "pages/mine/index",
        "text": "我的"
      }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^zw-(.*)": "@/components/zw-$1/zw-$1.vue",
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  }
}
