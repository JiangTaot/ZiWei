# ZiWei Server 环境变量配置模板
# 复制为 .env 并填入实际值: cp .env.example .env

# ---- 数据库（同机部署，桥接模式通过 host.docker.internal 访问宿主机） ----
MYSQL_HOST=host.docker.internal
MYSQL_PORT=13306
MYSQL_DB=ziwei
MYSQL_USER=root
MYSQL_PASSWORD=your-db-password

# ---- Redis（同机部署） ----
REDIS_HOST=host.docker.internal
REDIS_PORT=16379

# ---- 镜像仓库 ----
IMAGE_REGISTRY=111.229.214.14:15001
IMAGE_TAG=latest

# ---- 应用端口 ----
APP_PORT=48121

# ---- DeepSeek AI API Key（必填） ----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ---- JWT 签名密钥（生产环境务必修改） ----
JWT_SECRET=ziwei-doushu-jwt-secret-key-2024

# ---- 微信小程序（必填） ----
WECHAT_APP_ID=wxff8f8bad3c726539
WECHAT_APP_SECRET=your-wechat-app-secret
